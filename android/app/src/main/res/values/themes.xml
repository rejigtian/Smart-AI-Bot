<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Smartandroidbot" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Electric-cyan primary -->
        <item name="colorPrimary">@color/cyan_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/cyan_soft</item>
        <item name="colorOnPrimaryContainer">@color/cyan_deep</item>
        <item name="colorSecondary">@color/cyan_deep</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSecondaryContainer">@color/cyan_soft</item>
        <item name="colorOnSecondaryContainer">@color/cyan_deep</item>
        <!-- Cool light surfaces -->
        <item name="android:colorBackground">@color/canvas_soft</item>
        <item name="colorSurface">@color/canvas</item>
        <item name="colorOnSurface">@color/ink</item>
        <item name="colorSurfaceVariant">@color/canvas_cool</item>
        <item name="colorOnSurfaceVariant">@color/ink_mute</item>
        <item name="colorOutline">@color/hairline_strong</item>
        <item name="colorOutlineVariant">@color/hairline</item>
        <item name="colorError">@color/dot_red</item>
        <!-- Light status bar (dark icons over the cool canvas) -->
        <item name="android:statusBarColor">@color/canvas_soft</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Invisible activity used by the keep-alive recovery flow -->
    <style name="Theme.Transparent" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:colorBackgroundCacheHint">@null</item>
        <item name="android:windowIsTranslucent">true</item>
        <item name="android:windowAnimationStyle">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:backgroundDimEnabled">false</item>
    </style>
</resources>
